<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Team Management System</display-name>

    <!-- Configure these values for the database used by the target Tomcat runtime. -->
    <context-param>
        <param-name>jdbc.driver</param-name>
        <param-value></param-value>
    </context-param>
    <context-param>
        <param-name>jdbc.url</param-name>
        <param-value>jdbc:derby:memory:team_management;create=true</param-value>
    </context-param>
    <context-param>
        <param-name>jdbc.username</param-name>
        <param-value></param-value>
    </context-param>
    <context-param>
        <param-name>jdbc.password</param-name>
        <param-value></param-value>
    </context-param>

    <listener>
        <listener-class>web.listener.ApplicationContextListener</listener-class>
    </listener>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>web.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>web.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>web.servlet.DashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TeamServlet</servlet-name>
        <servlet-class>web.servlet.TeamServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SwapTeamServlet</servlet-name>
        <servlet-class>web.servlet.SwapTeamServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>PlayersApiServlet</servlet-name>
        <servlet-class>web.servlet.PlayersApiServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TeamsXmlServlet</servlet-name>
        <servlet-class>web.servlet.TeamsXmlServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TeamServlet</servlet-name>
        <url-pattern>/team</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SwapTeamServlet</servlet-name>
        <url-pattern>/swap</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PlayersApiServlet</servlet-name>
        <url-pattern>/api/players</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TeamsXmlServlet</servlet-name>
        <url-pattern>/api/teams.xml</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
