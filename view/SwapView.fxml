<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.SwapController" styleClass="background">

    <top>
        <StackPane>
            <ImageView preserveRatio="true" fitHeight="180">
                <image>
                    <Image url="@image/banner.png"/>
                </image>
            </ImageView>
        </StackPane>
    </top>

    <center>
        <VBox spacing="6">
            <HBox alignment="CENTER" styleClass="panel-bar">
                <Label text="Swap Team" styleClass="heading"/>
            </HBox>
            <ListView fx:id="teamLv" prefHeight="230"/>
            <HBox alignment="CENTER" spacing="10" styleClass="panel-bar">
                <Label text="Add Team:"/>
                <ComboBox fx:id="addTeamCb" prefWidth="220"/>
                <ImageView fx:id="addTeamJerseyIv" fitHeight="48" preserveRatio="true"/>
                <Button fx:id="addTeamBtn" text="Add Team" onAction="#addTeam" styleClass="button" prefWidth="150"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="12" styleClass="panel-bar">
            <Button fx:id="swapBtn" text="Swap"  onAction="#swap"  styleClass="button" prefWidth="240"/>
            <Button               text="Close" onAction="#close" styleClass="button" prefWidth="240"/>
        </HBox>
    </bottom>

    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>
</BorderPane>
