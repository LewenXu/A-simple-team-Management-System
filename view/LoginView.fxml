<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.LoginController"
      alignment="CENTER" styleClass="background" spacing="10" prefWidth="540">

    <ImageView fitWidth="540" fitHeight="300" preserveRatio="true">
        <image>
            <Image url="@/view/image/banner.png"/>
        </image>
    </ImageView>

    <Label text="Login" styleClass="heading"/>

    <HBox alignment="CENTER" spacing="10">
        <Label text="Manager ID:"/>
        <TextField fx:id="idTf" prefColumnCount="12" onAction="#handleLogin"/>
    </HBox>

    <HBox alignment="CENTER" spacing="10">
        <Button text="Login" onAction="#handleLogin" defaultButton="true" styleClass="button" prefWidth="240"/>
        <Button text="Exit" onAction="#handleExit" cancelButton="true" styleClass="button" prefWidth="240"/>
    </HBox>

    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>
</VBox>
